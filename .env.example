# Скопируй в .env и заполни значения:  cp .env.example .env
# .env добавлен в .gitignore — не коммить реальные секреты!

# --- HTTP ---
SERVER_PORT=8080
LOG_LEVEL=debug

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=managerFiles
DB_MAX_CONNS=10

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- MinIO (S3-совместимое хранилище) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=files
MINIO_USE_SSL=false

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=managerfiles-group

# --- JWT ---
# Генерация: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# --- AES-256 шифрование файлов ---
# Генерация: openssl rand -hex 32
ENCRYPTION_KEY=your_64_hex_chars_here

# --- Workers ---
WORKER_COUNT=5
